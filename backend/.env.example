# Slopsmith Node.js backend — copy to .env and fill in your values

# --- Required ---
# Absolute path to the directory containing your PSARC / sloppak files
DLC_DIR=/path/to/your/library

# --- Optional ---
# Where to store the SQLite DB, caches, and plugin pip packages.
# Defaults to ~/.local/share/rocksmith-cdlc
CONFIG_DIR=

# Path to the rscli binary (SNG → XML converter). Auto-detected if on PATH.
RSCLI_PATH=

# Path to vgmstream-cli (WEM decoder). Auto-detected if on PATH.
VGMSTREAM_CLI=

# TCP port to listen on
PORT=8080

# Host to bind
HOST=0.0.0.0

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Set to "true" to pretty-print logs (dev only)
LOG_PRETTY=false

# Set to "1" to enable read-only demo mode (blocks POST/DELETE)
SLOPSMITH_DEMO_MODE=

# User-managed extra plugins directory (supplements built-in plugins/)
SLOPSMITH_PLUGINS_DIR=

# If set, expose GET /api/audio-local-path (Electron integration only)
ELECTRON_MODE=

# Optional: Override the source URL shown in Settings → About
APP_SOURCE_URL=https://github.com/byrongamatos/slopsmith

# Optional: Override the license URL (defaults to APP_SOURCE_URL/blob/main/LICENSE)
APP_LICENSE_URL=

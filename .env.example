# Copy this file to .env and adjust for your system.
# docker-compose.yml reads .env automatically for variable substitution.

# Path to your Rocksmith 2014 DLC folder on the host machine.
# This is mounted into the container at /dlc.
DLC_PATH=~/.local/share/Steam/steamapps/common/Rocksmith2014/dlc

# MinIO (S3-compatible object storage) — used for cover art & audio uploads
# These match the defaults in docker-compose.yml; override for custom setups.
# MINIO_ENDPOINT=minio
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=slopsmith
# MINIO_SECRET_KEY=slopsmith123
# MINIO_BUCKET=slopsmith
